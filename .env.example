# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ACCESS_TOKEN=
JWT_SECRET=
LEGACY_JWT_SECRET=
GEMINI_API_KEY=

# 需要代理访问 GitHub 时：在 .env 配置下面两项，并用 pnpm dev:proxy 启动（通过 NODE_OPTIONS 加载 global-agent，无需 https-proxy-agent）
# GLOBAL_AGENT_HTTP_PROXY=http://127.0.0.1:7890
# GLOBAL_AGENT_HTTPS_PROXY=http://127.0.0.1:7890

# -----------------------------------------------------------------------------
# Database (MySQL - PlanetScale)
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://root:root@localhost:3306/taxonomy?schema=public"

# -----------------------------------------------------------------------------
# Email (Postmark)
# -----------------------------------------------------------------------------
SMTP_FROM=
POSTMARK_API_TOKEN=
POSTMARK_SIGN_IN_TEMPLATE=
POSTMARK_ACTIVATION_TEMPLATE=

# -----------------------------------------------------------------------------
# Subscriptions (Stripe)
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PLAN_ID=

# -----------------------------------------------------------------------------
# Legacy service compatibility (simple-nextjs-jwt)
# -----------------------------------------------------------------------------
PORT=3126
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=nextjs_jwt

# 兼容旧项目代理变量（legacy API 可能读取）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# Telegram（后续 legacy telegram 接口迁移会使用）
TEST_TELEGRAM_TOKEN=
TEST_GROUP_ID=